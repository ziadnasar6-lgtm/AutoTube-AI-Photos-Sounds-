          }
        ]
      ]
    },
    "Wait 10s Shotstack": {
      "main": [
        [
          {
            "node": "Shotstack Poll Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Shotstack Poll Result": {
      "main": [
        [
